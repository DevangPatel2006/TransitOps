{
  "name": "transitops-backend",
  "version": "1.0.0",
  "description": "TransitOps Backend API",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
